# ===== KINETIC HERMETICS — ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kinetic-hermetics

# JWT
JWT_SECRET=your-very-long-random-secret-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Email (Nodemailer / SendGrid)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=YOUR_SENDGRID_API_KEY
EMAIL_FROM=hello@kinetichemetics.com
EMAIL_FROM_NAME=Kinetic Hermetics

# ConvertKit (optional email marketing)
CONVERTKIT_API_KEY=YOUR_CONVERTKIT_API_KEY
CONVERTKIT_FORM_ID=YOUR_FORM_ID

# GoHighLevel (optional CRM)
GHL_API_KEY=YOUR_GHL_API_KEY
GHL_LOCATION_ID=YOUR_LOCATION_ID

# Frontend URL (for CORS & emails)
FRONTEND_URL=https://kinetichemetics.com
